// ── HELPERS ───────────────────────────────────────────────────────────────────
function fmt(n){
  if(n>=1_000_000){const m=n/1_000_000;return`€${Number.isInteger(m)?m:m.toFixed(1)}M`}
  return`€${Math.round(n/1000)}K`
}
function posLabel(p){return{DEL:'Delantero',MED:'Mediocampista',DEF:'Defensa',POR:'Arquero'}[p]}
function init(n){const p=n.split(' ');return p[p.length-1][0].toUpperCase()}

// ── ERROR handler ─────────────────────────────────────────────────────────────
function imgErr(img){
  img.classList.add('err');
  const initEl = img.nextElementSibling;
  if(initEl) initEl.style.display='flex';
}

// ── CARGA DE FOTOS DE WIKIPEDIA ───────────────────────────────────────────────
async function loadWikiPhotos(players, grid) {
  const imgs  = grid.querySelectorAll('.c-img');
  const inits = grid.querySelectorAll('.c-init');
  players.forEach(async (j, i) => {
    if (!j.wiki || !imgs[i]) return;
    try {
      const url = `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(j.wiki)}`;
      const r = await fetch(url, {referrerPolicy:'no-referrer'});
      if (!r.ok) return;
      const data = await r.json();
      const thumb = data?.thumbnail?.source;
      if (thumb) {
        const big = thumb.replace(/\/\d+px-/, '/400px-');
        imgs[i].onload = () => {
          imgs[i].classList.remove('err');
          if (inits[i]) inits[i].style.display = 'none';
        };
        imgs[i].src = big;
      }
    } catch(e) {}
  });
}

// ── RENDER CARD (Neón Dark) ───────────────────────────────────────────────────
function card(j){
  const stats = genStats(j);
  const statsHtml = stats.map(s=>`<div class="c-stat"><span class="c-sv">${s.v}</span><span class="c-sk">${s.k}</span></div>`).join('');
  const initials = init(j.nombre);
  const tag = j.promesa ? '<span class="c-tag">⭐ Promesa</span>' : `<span class="c-tag">${j.abr}</span>`;
  return`<div class="card ${j.pos}">
    <div class="c-bar"></div>
    <div class="c-photo">
      <div class="c-rating">
        <span class="c-ovr">${j.media}</span>
        <span class="c-pos">${j.abr}</span>
      </div>
      <div class="c-img-wrap">
        <img class="c-img"
             src="${CDN(j.fid)}"
             alt="${j.nombre}"
             referrerpolicy="no-referrer"
             crossorigin="anonymous"
             onerror="imgErr(this)">
        <div class="c-init">${initials}</div>
      </div>
    </div>
    <div class="c-sep"></div>
    <div class="c-info">
      <div class="c-name">${j.nombre}</div>
      <div class="c-meta">${j.edad} años · ${posLabel(j.pos)}</div>
      <div class="c-stats">${statsHtml}</div>
      <div class="c-bottom">
        <span class="c-price">${fmt(j.precio)}</span>
        ${tag}
      </div>
    </div>
  </div>`
}

// ── BUSCAR ────────────────────────────────────────────────────────────────────
function buscar(){
  const budget=+document.getElementById('budget').value;
  const pos=document.getElementById('position').value;
  const grid=document.getElementById('grid');
  const empty=document.getElementById('empty');
  const sw=document.getElementById('sw');
  const inp=document.getElementById('budget');

  if(!budget||budget<=0){
    inp.style.borderColor='#c02a1e';
    inp.style.boxShadow='0 0 0 3px rgba(192,42,30,.18)';
    setTimeout(()=>{inp.style.borderColor='';inp.style.boxShadow=''},1400);
    return;
  }

  let res=jugadores.filter(j=>j.precio<=budget);
  if(pos!=='ALL') res=res.filter(j=>j.pos===pos);
  res.sort((a,b)=>a.precio-b.precio);
  grid.innerHTML='';

  if(!res.length){
    empty.style.display='block'; sw.style.display='none';
  } else {
    empty.style.display='none';
    grid.innerHTML=res.map(card).join('');
    loadWikiPhotos(res, grid);
    const pr=res.map(j=>j.precio);
    const avg=(res.reduce((s,j)=>s+j.media,0)/res.length).toFixed(1);
    document.getElementById('sCount').textContent=res.length;
    document.getElementById('sMin').textContent=fmt(Math.min(...pr));
    document.getElementById('sMax').textContent=fmt(Math.max(...pr));
    document.getElementById('sAvg').textContent=avg;
    sw.style.display='block';
  }
  grid.scrollIntoView({behavior:'smooth',block:'start'});
}

document.getElementById('budget').addEventListener('keydown',e=>{if(e.key==='Enter')buscar()});

